# Application
NODE_ENV=development
PORT=4000

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/company_profile?schema=public"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="7d"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"
